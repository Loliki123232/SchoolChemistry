<UserControl x:Class="SchoolChemistry.Views.ElementDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Символ элемента (крупно) -->
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                   Text="{Binding Symbol}" 
                   FontSize="48" FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,20"/>

        <!-- Название -->
        <TextBlock Grid.Row="1" Grid.Column="0" 
                   Text="Название:" FontWeight="Bold"/>
        <TextBlock Grid.Row="1" Grid.Column="1" 
                   Text="{Binding Name}" FontSize="14"/>

        <!-- Атомный номер -->
        <TextBlock Grid.Row="2" Grid.Column="0" 
                   Text="Атомный номер:" FontWeight="Bold"/>
        <TextBlock Grid.Row="2" Grid.Column="1" 
                   Text="{Binding AtomicNumber}"/>

        <!-- Атомная масса -->
        <TextBlock Grid.Row="3" Grid.Column="0" 
                   Text="Атомная масса:" FontWeight="Bold"/>
        <TextBlock Grid.Row="3" Grid.Column="1" 
                   Text="{Binding AtomicMass}"/>

        <!-- Группа -->
        <TextBlock Grid.Row="4" Grid.Column="0" 
                   Text="Группа:" FontWeight="Bold"/>
        <TextBlock Grid.Row="4" Grid.Column="1" 
                   Text="{Binding GroupNumber}"/>

        <!-- Период -->
        <TextBlock Grid.Row="5" Grid.Column="0" 
                   Text="Период:" FontWeight="Bold"/>
        <TextBlock Grid.Row="5" Grid.Column="1" 
                   Text="{Binding Period}"/>

        <!-- Описание -->
        <TextBlock Grid.Row="6" Grid.Column="0" 
                   Text="Описание:" FontWeight="Bold"/>
        <TextBlock Grid.Row="6" Grid.Column="1" 
                   Text="{Binding Description}" 
                   TextWrapping="Wrap" Margin="0,0,0,10"/>

    </Grid>
</UserControl>